// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  geoPath   GeoPath[]
  todo      TodoItem[]
  session   Session?
}

// ------------------------- TODO -------------------------

model TodoItem {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  done        Boolean  @default(false)
}

// ------------------------- GEO PATHS -------------------------

model GeoPath {
  id     Int       @id @default(autoincrement())
  name   String
  cords  GeoCord[]
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}

model GeoCord {
  id     Int     @id @default(autoincrement())
  long   Float
  lat    Float
  path   GeoPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  pathId Int
}

model Session {
  id        String   @id @default(cuid()) // lub uuid() jeśli wolisz
  userId    Int      @unique
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  // opcjonalnie: relacja do modelu User, jeśli masz taki model
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------- SPOTLIGHT -------------------------

model Spotlight {
  id          String              @id @default(cuid())
  title       String
  description String
  userId      String
  lat         Float
  lng         Float
  isActive    Boolean             @default(true)
  visibility  Visibility          @default(PUBLIC)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  categories  SpotlightCategory[]
  media       SpotlightMedia[]
  comments    SpotlightComment[]
  rates       SpotlightRate[]
}

enum Visibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

model SpotlightCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  iconUrl     String?
  coverImage  String?
  isActive    Boolean     @default(true)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  spotlights  Spotlight[]
}

model SpotlightMedia {
  id          String   @id @default(cuid())
  spotlightId String
  spotlight   Spotlight @relation(fields: [spotlightId], references: [id], onDelete: Cascade)
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  src         String
  userId      String
}

model SpotlightComment {
  id          String    @id @default(cuid())
  spotlightId String
  spotlight   Spotlight @relation(fields: [spotlightId], references: [id], onDelete: Cascade)
  content     String
  isActive    Boolean   @default(true)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SpotlightMediaComment {
  id          String   @id @default(cuid())
  spotlightId String
  mediaId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  content     String
  userId      String
}

model SpotlightRate {
  id          String    @id @default(cuid())
  spotlightId String
  spotlight   Spotlight @relation(fields: [spotlightId], references: [id], onDelete: Cascade)
  value       Int
  userId      String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
